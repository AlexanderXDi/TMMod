        "north": "true"
      },
      "apply": {
        "model": "tmmod:block/cables/glass_cable/glass_cable_north"
      }
    },
    {
      "when": {
        "east": "true"
      },
      "apply": {
        "model": "tmmod:block/cables/glass_cable/glass_cable_east"
      }
