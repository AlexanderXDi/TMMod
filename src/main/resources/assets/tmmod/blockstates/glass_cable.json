      },
      "apply": {
        "model": "tmmod:block/cables/glass_cable/glass_cable_south"
      }
    },
    {
      "when": {
        "west": "true"
      },
      "apply": {
        "model": "tmmod:block/cables/glass_cable/glass_cable_west"
      }
    },
    {
      "when": {
        "up": "true"
      },
      "apply": {
        "model": "tmmod:block/cables/glass_cable/glass_cable_up"
